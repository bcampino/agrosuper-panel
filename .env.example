# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Webhook security — ENEX/legacy forms
DATASCOPE_WEBHOOK_SECRET=
# Legacy alias (either one works):
# WEBHOOK_SHARED_SECRET=

# Set to "false" ONLY in local dev to skip webhook secret verification.
# Any other value (including unset) enforces verification.
# ENFORCE_DATASCOPE_WEBHOOK_SECRET=false

# Webhook security — Agrosuper (required in production)
AGROSUPER_WEBHOOK_SECRET=

# Optional: direct Postgres connection for scripts that need it
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# Optional: CSV path override for comparison/backfill scripts
# ENEX_COMPARE_CSV_PATH=
# ENEX_WEBHOOK_CSV_PATH=
